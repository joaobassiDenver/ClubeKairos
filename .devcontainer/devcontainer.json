{
  "name": "Clube Kairos — React + FastAPI",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "customizations": {
    "codespaces": {
      "openFiles": [
        "frontend/src/App.tsx"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "updateContentCommand": "pip3 install --user -r requirements.txt && cd frontend && npm install",
  "postAttachCommand": {
    "backend": "python -m uvicorn backend.main:app --reload --host 0.0.0.0 --port 8000",
    "frontend": "cd frontend && npm run dev -- --host 0.0.0.0"
  },
  "portsAttributes": {
    "8000": {
      "label": "Backend API",
      "onAutoForward": "silent"
    },
    "5173": {
      "label": "Frontend App",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [8000, 5173]
}
